# Goal
ChatMessage[] messages       # 完整对话上下文
bool stream                  # true=流式, false=阻塞
int32 max_context_tokens     # 最大上下文 token 数, 0 表示不限制 (粗略估算)
string truncation_strategy   # 截断策略, 目前仅支持 "drop_oldest", 空字符串表示不截断
string reasoning_effort      # 思考等级: "low", "medium", "high", 空字符串表示使用模型默认
---
# Result
string content               # 最终回复文本
string reasoning_content     # 思考内容 (如果模型提供)
ChatMessage[] updated_messages # 加入 assistant 回复后的完整上下文
bool success
string error_msg
int32 prompt_tokens          # 提示词 token 数 (若获取到)
int32 completion_tokens      # 补全 token 数
int32 total_tokens           # 总 token 数
---
# Feedback
string partial_content       # 流式增量文本
string partial_reasoning     # 流式增量思考内容